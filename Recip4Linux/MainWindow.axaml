<!--Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Recip4Linux.MainWindow"
        Title="Recip4Linux">
    Welcome to Avalonia!
</-Window>
-->

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:GroupBox.Avalonia.Controls"
        xmlns:local="using:Recip4Linux"
        x:Class="Recip4Linux.MainWindow"
        Title="Recip v1.2"
        Width="500" Height="230"
        CanResize="False"
        Icon="/Resources/recipiconnbnew.ico">

  <DockPanel>
    <!-- Menú superior -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File" x:Name="fileToolStripMenuItem">
        <MenuItem Header="_New" Click="New_Click" x:Name="newToolStripMenuItem"/>
        <MenuItem Header="_Open" Click="Open_Click" x:Name="openToolStripMenuItem"/>
        <MenuItem Header="On_line" Click="Online_Click"/>
      </MenuItem>

      <MenuItem Header="_Language" x:Name="languageToolStripMenuItem">
        <MenuItem Header=".\" Click="Lang_Click" x:Name="toolStripMenuItem2"/>
      </MenuItem>

      <MenuItem Header="_Help" x:Name="helpToolStripMenuItem">
        <MenuItem Header="About Recip" Click="About_Click" x:Name="aboutRecipToolStripMenuItem"/>
      </MenuItem>
    </Menu>

    <!-- Contenido principal -->
    <Grid Margin="10" RowDefinitions="Auto,*,Auto" ColumnDefinitions="Auto,*">
      <!-- Izquierda -->
      <StackPanel Orientation="Vertical" Grid.Row="0" Grid.Column="0" Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Open" Width="84" Click="Open_Click" x:Name="button1"/>
          <Button Content="New" Width="84" Click="New_Click" x:Name="button2"/>
          <Button Content="Online" Width="84" Click="Online_Click"/>
        </StackPanel>

        <controls:GroupBox Header="App settings" Width="285" Margin="0,10,0,0" x:Name="groupBox2">
          <StackPanel Spacing="6">
            <ComboBox Name="comboColor" Width="120" SelectedIndex="0" x:Name="comboBox1">
              <ComboBoxItem>Color</ComboBoxItem>
                <ComboBoxItem>B/W</ComboBoxItem>
                <ComboBoxItem>Mono</ComboBoxItem>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Set" Width="66" Click="Set_Click"/>
              <Button Content="↻ RESTART" FontWeight="Bold" Width="100" Click="Restart_Click" 
                      x:Name="button8" ToolTip.Tip="{x:Static local:Strings.ToolTipRestart}"/>
              <Button Content="↺ RESET" FontWeight="Bold" Width="80" Click="Reset_Click" x:Name="button7"
                      ToolTip.Tip="{x:Static local:Strings.ToolTipReset}"/>
            </StackPanel>
          </StackPanel>
        </controls:GroupBox>
      </StackPanel>

      <!-- Derecha -->
      <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
          <Image Source="/Resources/recip_new.png" Width="64" Height="64" x:Name="pictureBox1"/>
          <TextBlock Text="v1.2" Margin="10,40,0,0"/>
        </StackPanel>

        <controls:GroupBox Header="Recent" Width="190" Margin="0,10,0,0" x:Name="groupBox1">
          <StackPanel Spacing="4">
            <Button Content="(recipename)" Click="Recent1_Click" x:Name="Recent1"/>
            <Button Content="(recipename)" Click="Recent2_Click" x:Name="Recent2"/>
          </StackPanel>
        </controls:GroupBox>
      </StackPanel>
    </Grid>
  </DockPanel>
</Window>
